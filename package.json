{
  "name": "mitm-core",
  "version": "0.0.1",
  "description": "A high-performance, fully extensible Man-in-the-Middle (MITM) proxy framework for Node.js. Built completely in TypeScript, it provides a strictly-typed pipeline for intercepting, modifying, and analyzing HTTP/HTTPS traffic.",
  "keywords": [
    "proxy",
    "mitm",
    "man-in-the-middle",
    "http-proxy",
    "https-proxy",
    "tls-interception",
    "ssl-proxy",
    "network-interception",
    "traffic-analysis",
    "tunnel",
    "middleware",
    "pipeline",
    "framework",
    "node-forge",
    "dynamic-certificates",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsx watch --inspect ./example/with-plugin/Proxy.ts",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src",
    "format": "prettier --write src",
    "test": "mocha --config mocha.config.json",
    "build": "tsup",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run lint && npm run typecheck",
    "release": "commit-and-tag-version"
  },
  "author": "Debanshu Panigrahi",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.2",
    "@types/node-forge": "^1.3.14",
    "@types/ws": "^8.18.1",
    "commit-and-tag-version": "^12.7.1",
    "cross-env": "^10.1.0",
    "mocha": "^11.3.0",
    "node-forge": "^1.4.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "undici": "^7.25.0"
  },
  "commit-and-tag-version": {
    "skip": {
      "changelog": true
    }
  },
  "dependencies": {
    "lru-cache": "^11.2.4",
    "piscina": "^5.1.4"
  },
  "directories": {
    "example": "example",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debanshup/mitm-core.git"
  },
  "bugs": {
    "url": "https://github.com/debanshup/mitm-core/issues"
  },
  "homepage": "https://github.com/debanshup/mitm-core#readme"
}
