{
  "compilerOptions": {
    "target": "ES2022",
    // Switch to Bundler since tsup owns compilation — no more .js extension enforcement
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "node",
      "mocha"
    ],
    "outDir": "./dist",
    "rootDir": ".",
    /* Emit */
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "noEmitOnError": true, // ← added: don't emit broken output
    /* Strictness */
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "example/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
  ]
}